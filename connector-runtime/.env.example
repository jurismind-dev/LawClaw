# 公网中继地址（lawclaw-app 部署域名）
RELAY_URL=https://lawclaw-app.jurismind.com

# 连接器显示名称（可选）
CONNECTOR_NAME=My-LawClaw

# 本机 OpenClaw Gateway 地址（可选，默认本机 18789）
OPENCLAW_GATEWAY_URL=ws://127.0.0.1:18789

# 可选：手动覆盖 Gateway Token（不填则自动从 ~/.openclaw/openclaw.json 读取）
# OPENCLAW_GATEWAY_TOKEN=replace-with-local-gateway-token

# 可选：如果你想禁用自动浏览器授权，可改为 false 并手动设置 CONNECTOR_TOKEN
# CONNECTOR_AUTO_AUTHORIZE=true

# 连接器授权模式：
# pair      = 扫码绑定（默认，推荐）
# redirect  = 浏览器回调（旧模式）
# CONNECTOR_AUTH_MODE=pair

# 扫码模式失败时是否回退到浏览器回调（默认 false，建议保持 false）
# CONNECTOR_PAIR_FALLBACK_REDIRECT=false

# 扫码绑定轮询间隔（毫秒）
# CONNECTOR_PAIR_POLL_INTERVAL_MS=2000

# 扫码绑定时是否自动在本机打开授权页（默认 false）
# CONNECTOR_PAIR_OPEN_BROWSER=false
